# ── Supabase / Prisma configuration ───────────────────────────────────────────
# Copy to .env.local (git-ignored) and fill in the secrets from your Supabase
# project dashboard. All four are server-side only — none are read in the browser.

# Prisma connection strings (Supabase Postgres).
#   DATABASE_URL : POOLED connection (PgBouncer, port 6543) used at runtime.
#                  Keep the ?pgbouncer=true flag for serverless safety.
#   DIRECT_URL   : DIRECT connection (port 5432) used for `prisma db push` / migrations.
# Copy both from: Supabase Dashboard → Connect → ORMs → Prisma.
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@<pooler-host>:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<db-password>@<pooler-host>:5432/postgres"

# Supabase project API URL (used server-side to build public Storage URLs and
# the upload client; also used by @supabase/ssr in the browser). Dashboard →
# Settings → API → Project URL.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"

# Anon (public) key — safe in the browser. Powers user authentication via
# @supabase/ssr. Dashboard → Settings → API → Project API keys → anon/public.
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"

# Service-role (secret) key — used ONLY in API routes to upload screenshots to
# Storage. NEVER expose this to the browser. Dashboard → Settings → API →
# Project API keys → service_role.
SUPABASE_SERVICE_ROLE_KEY="<service-role-secret-key>"
